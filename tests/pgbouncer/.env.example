# PgBouncer Connection Test Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Option 1: Full connection URL (takes priority if set)
DATABASE_PUBLIC_URL=postgres://postgres:your_password@interchange.proxy.rlwy.net:34014/railway

# Option 2: Individual connection parameters (used if DATABASE_PUBLIC_URL is not set)
# PGBOUNCER_HOST=interchange.proxy.rlwy.net
# PGBOUNCER_PORT=34014
# PGBOUNCER_USER=postgres
# PGBOUNCER_PASSWORD=your_password
# PGBOUNCER_DATABASE=railway
