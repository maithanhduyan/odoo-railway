{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "watchPatterns": [
      "/minio/**"
    ],
    "dockerfilePath": "/minio/Dockerfile"
  },
  "deploy": {
    "startCommand": "/bin/sh /entrypoint.sh",
    "runtime": "V2",
    "numReplicas": 1,
    "sleepApplication": false,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
